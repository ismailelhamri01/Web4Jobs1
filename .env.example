# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_SHEETS_SPREADSHEET_ID: The ID from your Google Sheets URL.
# Example URL: https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID="MY_SPREADSHEET_ID"

# GOOGLE_SHEETS_API_KEY: API key allowed to read the Google Sheets API.
GOOGLE_SHEETS_API_KEY="MY_GOOGLE_SHEETS_API_KEY"

# GOOGLE_SERVICE_ACCOUNT_EMAIL / GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY:
# Required on Vercel if the Google Sheet is private.
# Share the Google Sheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Viewer.
GOOGLE_SERVICE_ACCOUNT_EMAIL="my-service-account@my-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMY_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# GOOGLE_SHEETS_RANGE: Sheet tab or A1 range to read. Use the tab name from Google Sheets.
# Example: "Sidi Kacem" or "'Sidi Kacem'!A:K". Defaults to "Sheet1".
GOOGLE_SHEETS_RANGE="Sidi Kacem"

# GOOGLE_SHEETS_CITY_COLUMN: Header containing the city/center name. Defaults to "Centre".
GOOGLE_SHEETS_CITY_COLUMN="Centre"

# GOOGLE_SHEETS_PERCENTAGE_COLUMN: Header containing numeric progress values.
# In your Sidi Kacem file, this is the percentage column, not the course-name "Certification 1" column.
GOOGLE_SHEETS_PERCENTAGE_COLUMN="Pourcentage de complétion de la certification 1"
